# =========================================================
# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env al repositorio
# =========================================================

# Servidor
PORT=3001
# Cambiar a "production" en el servidor de producción
NODE_ENV=development

# =========================================================
# CORS
# =========================================================
FRONTEND_URL=https://qr-acceso-cielito-home.web.app
ALLOWED_ORIGINS=http://localhost:5173,https://qr-acceso-cielito-home.web.app

# =========================================================
# FIREBASE ADMIN SDK
# Obtener en: Firebase Console > Configuración > Cuentas de servicio > Generar nueva clave privada
# Copiar los valores del JSON descargado aquí:
# =========================================================
FIREBASE_PROJECT_ID=qr-acceso-cielito-home
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@qr-acceso-cielito-home.iam.gserviceaccount.com
# La llave privada va en UNA sola línea, con \n literales (no saltos reales de línea)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXXXXXXXXXXXXXXXX\n-----END PRIVATE KEY-----\n"

# =========================================================
# ACCESO ADMIN
# =========================================================
ADMIN_EMAILS=admin@tuempresa.com,otro@tuempresa.com

# =========================================================
# NÓMINA — Contraseña de acceso al módulo de nómina
# =========================================================
PAYROLL_PASSWORD=CambiarEstaPorUnaSegura2025!

# =========================================================
# EMAIL SMTP — Para envío de recibos de nómina
# Gmail: habilitar "Contraseñas de aplicación" en la cuenta
# =========================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tucuenta@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# =========================================================
# RATE LIMITING
# =========================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =========================================================
# USUARIOS CON PERMISOS ESPECIALES (separados por coma)
# =========================================================
USUARIOS_MULTI_REGISTRO=sistemas@tuempresa.com
USUARIOS_REMOTOS=remoto1@tuempresa.com,remoto2@tuempresa.com
